{
  "name": "@casaper/llm-util",
  "version": "1.8.0",
  "description": "Personal experimental cli LLM utilities running on local Ollama models.",
  "bugs": {
    "url": "https://github.com/casaper/llm-util/issues"
  },
  "homepage": "https://github.com/casaper/llm-util#readme",
  "keywords": [
    "cli",
    "llm",
    "ollama",
    "markdown"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/casaper/llm-util.git"
  },
  "author": "Casaper <me@casaper.dev>",
  "license": "MIT",
  "main": "dist/llm-util.js",
  "types": "dist/types/llm-util.d.ts",
  "bin": {
    "llm-util": "dist/llm-util.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bash tasks/build_dist.sh",
    "release": "semantic-release",
    "prepare": "run-s build",
    "prepublishOnly": "run-s build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint --format unix 'src/**/*.ts' '*.{ts,mts}'",
    "fmt:prettier": "prettier -w '*.{json,yaml,yml,md}'",
    "fmt:eslint": "eslint --format unix --fix 'src/**/*.ts' '*.{ts,mts}'",
    "fmt": "run-s fmt:prettier fmt:eslint"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "cli-color": "^2.0.4",
    "commander": "^14.0.3",
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/cli-color": "^2.0.6",
    "@types/node": "^25.7.0",
    "@types/npmcli__promise-spawn": "^6.0.3",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-sh": "^0.18.1",
    "rambdax": "^11.3.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=25 <26"
  }
}
